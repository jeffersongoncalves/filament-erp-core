{
    "name": "jeffersongoncalves/filament-erp-core",
    "description": "Filament v5 panel resources for the Laravel ERP core — companies, currencies, units, fiscal years and organizational masters.",
    "keywords": [
        "laravel",
        "filament",
        "filament-plugin",
        "erp",
        "company",
        "currency",
        "uom"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Jefferson Gonçalves",
            "email": "gerson.simao.92@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.3",
        "jeffersongoncalves/laravel-erp-core": "^1.0",
        "spatie/laravel-package-tools": "^1.14.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.21",
        "orchestra/testbench": "^10.0|^11.0",
        "pestphp/pest": "^3.0|^4.0",
        "pestphp/pest-plugin-laravel": "^3.0|^4.0"
    },
    "autoload": {
        "psr-4": {
            "JeffersonGoncalves\\FilamentErp\\Core\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "JeffersonGoncalves\\FilamentErp\\Core\\Tests\\": "tests"
        }
    },
    "scripts": {
        "post-autoload-dump": "@php ./vendor/bin/testbench package:discover --ansi",
        "analyse": "vendor/bin/phpstan analyse",
        "format": "vendor/bin/pint",
        "test": "vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "phpstan/extension-installer": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "JeffersonGoncalves\\FilamentErp\\Core\\FilamentErpCoreServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "homepage": "https://github.com/jeffersongoncalves/filament-erp",
    "support": {
        "issues": "https://github.com/jeffersongoncalves/filament-erp/issues",
        "source": "https://github.com/jeffersongoncalves/filament-erp"
    }
}
